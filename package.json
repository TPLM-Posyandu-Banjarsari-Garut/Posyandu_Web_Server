{
    "name": "my-express-app",
    "version": "1.0.0",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "NODE_ENV=development bun --watch src/server.ts",
        "start": "NODE_ENV=production bun dist/server.js",
        "build": "rm -rf dist && tsc && tsc-alias",
        "vercel-build": "bun run build",
        "typecheck": "tsc --noEmit",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "db:generate": "bunx drizzle-kit generate",
        "db:migrate": "bunx drizzle-kit migrate",
        "db:studio": "bunx drizzle-kit studio",
        "db:seed": "bun src/db/seed/vaccines-vitamins.ts",
        "format:check": "bunx prettier . --check",
        "format:fix": "bunx prettier . --write && bunx eslint . --fix",
        "docs": "bun swagger.config.ts",
        "test": "jest --passWithNoTests",
        "test:coverage": "jest --coverage --passWithNoTests",
        "prepare": "husky"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.ts": "bash -c 'tsc --noEmit'"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.9.1",
        "@types/pg": "^8.20.0",
        "@types/source-map-support": "^0.5.10",
        "@types/swagger-ui-express": "^4.1.8",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.4.0",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.0.5",
        "morgan": "^1.10.1",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.11",
        "tsc-alias": "^1.8.17",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@better-auth/drizzle-adapter": "^1.6.14",
        "better-auth": "^1.6.14",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "cross-env": "^10.1.0",
        "dotenv-flow": "^4.1.0",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0",
        "pg": "^8.21.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.9",
        "source-map-support": "^0.5.21",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.4.3"
    }
}
